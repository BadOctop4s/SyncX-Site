{
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/proximos",
      "destination": "/proximos.html"
    },
    {
      "source": "/outros-projetos",
      "destination": "/outros-projetos.html"
    },
    {
      "source": "/outros",
      "destination": "/outros-projetos.html"
    },
    {
      "source": "/getkey",
      "destination": "/getkey.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}